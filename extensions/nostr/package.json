{
  "name": "@xclaw/nostr",
  "version": "2026.3.22",
  "description": "XClaw Nostr channel plugin for NIP-04 encrypted DMs",
  "type": "module",
  "dependencies": {
    "nostr-tools": "^2.23.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "xclaw": "workspace:*"
  },
  "peerDependencies": {
    "xclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "xclaw": {
      "optional": true
    }
  },
  "xclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@xclaw/nostr",
      "localPath": "extensions/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
