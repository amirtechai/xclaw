{
  "name": "@xclaw/feishu",
  "version": "2026.3.22",
  "description": "XClaw Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@sinclair/typebox": "0.34.48",
    "https-proxy-agent": "^8.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "xclaw": "workspace:*"
  },
  "peerDependencies": {
    "xclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "xclaw": {
      "optional": true
    }
  },
  "xclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@xclaw/feishu",
      "localPath": "extensions/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
