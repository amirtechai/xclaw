// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

XCLAW_CODE_SIGN_STYLE = Automatic
XCLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

XCLAW_APP_BUNDLE_ID = ai.xclaw.client
XCLAW_SHARE_BUNDLE_ID = ai.xclaw.client.share
XCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.xclaw.client.activitywidget
XCLAW_WATCH_APP_BUNDLE_ID = ai.xclaw.client.watchkitapp
XCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.xclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
XCLAW_APP_PROFILE =
XCLAW_SHARE_PROFILE =
